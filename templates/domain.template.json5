// Golden template for bun-security-planner domains.
// Copy this file to domains/<domain>.security.json5 and edit only the fields
// that differ. Every field shown here is optional except `domain`.

{
	// Required. Reverse-DNS domain identifier.
	domain: 'com.example.service',

	// Display metadata.
	displayName: 'Example Service',
	description: 'One-line description of the domain.',

	// Brand / terminal colors.
	colors: {
		primary: '#0A84FF',
		secondary: '#30D158',
		fatal: '#FF453A',
		warn: '#FF9500',
		info: '#0A84FF',
		success: '#30D158',
	},

	// Channel color overrides for audit/log output.
	channels: {
		vault: '#0A84FF',
		identity: '#30D158',
		token: '#FF9500',
		csrf: '#FF453A',
		supplyChain: '#BF5AF2',
		ops: '#8E8E93',
	},

	// Vault / secrets configuration.
	secrets: {
		service: 'com.example.service',
		allowUnrestrictedAccess: false,
		inventory: [
			// { name: "api-key", required: true, description: "Production API key" },
		],
	},

	// Identity / password policy.
	identity: {
		algorithm: 'bcrypt',
		minLength: 12,
		requireSpecialChar: true,
	},

	// Token / signing policy.
	token: {
		algorithm: 'HS256',
		ttlSeconds: 3600,
		issuer: 'com.example.service',
	},

	// CSRF protection.
	csrf: {
		enabled: true,
		tokenLength: 32,
		// "stateless" or "session-bound" (Bun.CSRF sessionId binding).
		mode: 'session-bound',
		encoding: 'base64url',
		algorithm: 'sha256',
		cookieName: '_csrf',
		headerName: 'X-CSRF-Token',
		sessionCookieName: '_session',
	},

	// Supply-chain security.
	supplyChain: {
		enabled: true,
		feed: {
			remote: 'https://threats.factory-wager.com/v1/bun-feed',
			apiKeyVault: 'threat-feed-api-key',
			cachePath: './.security/threat-cache.json',
			cacheTtl: 3600,
			// protocol: 'http3',  // experimental Bun fetch (http2 | http3)
		},
		policy: {
			fatal: ['backdoor', 'botnet', 'token-stealer', 'malware'],
			warn: ['protestware', 'adware', 'deprecated', 'unmaintained'],
		},
	},

	// Service runtime (Bun.serve + external scanner orchestration).
	service: {
		// Enable Bun.Terminal PTY for interactive external scanners (trivy, snyk, etc.).
		// Requires a full TTY (stdin + stdout). Pipe JSON via `bun sp doctor --json | fx` instead.
		interactive: false,
		// port: 443,
		// hostname: '0.0.0.0',
		// http3: true,   // QUIC — requires tls below
		// http1: true,
		// tls: { cert: './certs/server.pem', key: './certs/server-key.pem' },
	},

	// Visual artifacts (Bun.Image, operator QR).
	visual: {
		qr: {
			// Master-token QR via `bun sp qr --domain <domain>` (default: true).
			enabled: true,
		},
	},

	// Operational settings.
	ops: {
		watch: {
			debounceMs: 300,
			report: null,
			output: null,
		},
		report: {
			// markdown | html | json — all formats include operator QR metadata when enabled.
			format: 'html',
			output: './.security/reports',
			operatorQr: {
				// Embed vault master-token QR in HTML reports (Bun.secrets + Bun.hash cache).
				enabled: true,
				size: 180,
				// dark: '#FF453A',
				// light: '#0A0A0F',
			},
		},
	},

	// Audit persistence.
	audit: {
		sqlite: {
			path: './.security/audit.sqlite',
			// Master key can be supplied via AUDIT_MASTER_KEY env var.
			masterKey: null,
			compress: true,
			compressionFormat: 'zstd',
		},
	},

	// Threat intelligence.
	intel: {
		dns: {
			blocklist: [],
			requireResolution: true,
			suspiciousTtlThreshold: 60,
		},
	},

	// Remote TLS inspection (`bun sp tls`, `bun scan tls`).
	tls: {
		// Validate against the OS trust store (tls.getCACertificates('system')).
		// Bun >= 1.3.14 loads system CAs without --use-system-ca; validation auto-enables
		// when the store is non-empty. On managed macOS, enumeration no longer triggers
		// trustd OCSP/CRL/AIA fetches (safe for NetworkExtension content filters).
		// Set false to skip, true to force.
		// useSystemCA: false,
	},

	// Universal error code overrides.
	errorOverrides: {
		// VAULT_MISSING: { severity: "fatal", channel: "vault" },
	},
}
