{
	"name": "@acme/bun-security-scanner",
	"description": "Bun security scanner for Acme Corp — supply chain protection with local rules + remote threat intelligence",
	"version": "1.0.0",
	"type": "module",
	"author": {
		"name": "Acme Corp Security Team",
		"email": "security@acme.example.com",
		"url": "https://acme.corp/security"
	},
	"license": "MIT",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"bun": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./rules": "./rules/security-rules.json",
		"./rules.json": "./rules/security-rules.json",
		"./package.json": "./package.json"
	},
	"types": "./src/index.ts",
	"files": [
		"src",
		"scripts",
		"rules",
		"CHANGELOG.md",
		"SECURITY.md"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/oven-sh/security-scanner-template"
	},
	"keywords": [
		"bun",
		"security-scanner",
		"supply-chain-security",
		"vulnerability",
		"threat-intel",
		"package-manager",
		"dependency-security",
		"security-governance"
	],
	"scripts": {
		"test": "bun test",
		"lint": "bunx prettier --check .",
		"typecheck": "bunx tsc --noEmit",
		"format": "bunx prettier --write .",
		"check": "bun run lint && bun run typecheck && bun run test",
		"check:registry": "bun run src/index.ts --check-registry",
		"healthcheck": "bun run src/index.ts --healthcheck",
		"detect-secrets-backend": "bun run scripts/detect-secrets-backend.ts",
		"prepublishOnly": "bun run check"
	},
	"dependencies": {
		"smol-toml": "^1.6.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "^1.2.20",
		"@types/node": "^26.0.0",
		"bun-types": "1.2.20",
		"prettier": "^3.6.2",
		"typescript": "^5.9.2"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"publishConfig": {
		"access": "restricted",
		"registry": "https://registry.mycompany.com"
	}
}
